---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Feature from '../components/blocks/features/FeatureSticky.astro'
import Hero from '../components/blocks/hero/PageHeader.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'

// Data
import featuresRaw from '../data/json-files/featuresData.json'
type FeatureItem = { title: string; icon: string; description: string; category: string }
const featuresData = featuresRaw as FeatureItem[]
// - Feature Categories
const featuresBatiment = featuresData.filter((feature) => feature.category === 'Batiment')
const featuresIndustrie = featuresData.filter((feature) => feature.category === 'Industrie')
const featuresGeomatique = featuresData.filter((feature) => feature.category === 'Geomatique')
const featuresLivrables = featuresData.filter((feature) => feature.category === 'Livrables' || feature.category === 'Securite')

// Content
// - SEO
const SEO = {
	title: 'VisuDrone | Nos services d\'inspection par drone',
	description:
		'Decouvrez tous nos services : inspection de batiments et facades, thermographie infrarouge, topographie RTK, modelisation 3D et rapports professionnels. Telepilote certifie DGAC.'
}
// - Page Header
const header = {
	title: 'Des solutions drone pour chaque <strong>mission d\'inspection</strong>.',
	text: 'Du batiment industriel au panneau solaire, nos drones captent tout ce que l\'oeil ne peut pas voir.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<Feature
		title="Inspection du bati"
		text="Toitures, facades, ouvrages d'art et structures industrielles inspectes sans echafaudage ni nacelle."
		data={featuresBatiment}
	/>
	<Feature
		title="Applications industrielles"
		text="Pylones, reseaux, panneaux solaires et sites en exploitation surveilles avec precision et sans interruption."
		data={featuresIndustrie}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<Feature
		title="Geomatique & relevés numeriques"
		text="Topographie, orthophotographie et modelisation 3D pour vos projets d'amenagement, BIM et etudes de terrain."
		data={featuresGeomatique}
	/>
	<Feature
		title="Livrables & certifications"
		text="Rapports professionnels remis sous 48h, certifies par un telepilote DGAC et conformes aux exigences des assureurs."
		data={featuresLivrables}
		classes="bg-neutral-50 dark:bg-neutral-900"
	/>
	<CTA />
</Layout>
