---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import FAQ from '../components/blocks/FAQ/FaqSticky.astro'
import TextImage from '../components/blocks/basic/TextImage.astro'
import CTA from '../components/blocks/CTA/BasicDark.astro'

// Data
import faqRaw from '../data/json-files/faqData.json'
type FaqItem = { question: string; reply: string; category: string; open: boolean }
const faqData = faqRaw as FaqItem[]
// - FAQ Categories
const faqMission = faqData.filter((faq) => faq.category === 'mission')
const faqLivrables = faqData.filter((faq) => faq.category === 'livrables' || faq.category === 'thermographie')
const faqReglementation = faqData.filter((faq) => faq.category === 'reglementation')

// Content
import faqImage1 from '../assets/faq/faq-01.png'
// - SEO
const SEO = {
	title: 'VisuDrone | FAQ - Questions frequentes sur l\'inspection par drone',
	description:
		'Toutes les reponses a vos questions sur nos missions d\'inspection par drone : zones d\'intervention, certifications, livrables, tarifs et deroulement des inspections.'
}
// - Page Header
const header = {
	title: 'Vos questions sur l\'<strong>inspection par drone</strong>.',
	text: 'Retrouvez ici les reponses aux questions les plus frequentes de nos clients.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<FAQ
		title="Organisation et deroulement des missions"
		text="Comment se deroule une inspection, quels sont les delais et ce qui est inclus dans la prestation."
		data={faqMission}
	/>
	<TextImage
		title="Des rapports professionnels livres sous 48h"
		text="Chaque mission VisuDrone donne lieu a un rapport detaille : photos georeferencees, annotations, cotation des anomalies et recommandations. Nos livrables sont compatibles avec les logiciels des bureaux d etudes."
		image={faqImage1}
		mobileImage={faqImage1}
		imagePosition="left"
		offsetImage
		classes="bg-neutral-50 dark:bg-neutral-900 lg:!py-64"
	/>
	<FAQ
		title="Thermographie, livrables et technique"
		text="Informations sur la thermographie infrarouge, les formats de livrables et les conditions d utilisation."
		data={faqLivrables}
	/>
	<FAQ
		title="Certifications et cadre reglementaire"
		text="Nos telepilotes sont certifies DGAC et nos operations respectent la reglementation europeenne EU 2019/947."
		data={faqReglementation}
	/>
	<CTA />
</Layout>
