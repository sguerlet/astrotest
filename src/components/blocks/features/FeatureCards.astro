---
// Feature Cards grid Section
// ------------
// Description: A grid of cards with feature information in a 4 column layout.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Card from '../../ui/cards/FeatureCard.astro'

// Content
// - Cards
import feature01 from '../../../assets/cards/feature-01.svg'
import feature02 from '../../../assets/cards/feature-02.svg'
import feature03 from '../../../assets/cards/feature-03.svg'
import feature04 from '../../../assets/cards/feature-04.svg'
import feature05 from '../../../assets/cards/feature-05.svg'
---

<Section id="features">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">Des missions drone pour chaque <strong>besoin d'inspection</strong></h2>
			<p class="pb-0 text-lg">
				De l'inspection de toiture à l'expertise d'ouvrage d'art, nos drones équipés de capteurs haute résolution
				produisent des données précises, exploitables immédiatement.
			</p>
		</Col>
	</Row>
	<Row>
		<Col span="4">
			<Card
				title="Inspection de toitures & façades"
				subtitle="Détection de désordres, infiltrations, fissures ou déformations sur tout type de bâtiment, sans nacelle ni échafaudage."
				image={feature01}
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Inspection d'ouvrages d'art"
				subtitle="Ponts, viaducs, pylônes, cheminées industrielles — localisation précise des défauts structurels avec rapport photo géolocalisé."
				image={feature02}
				link="/features"
			/>
			<Card
				title="Thermographie infrarouge"
				subtitle="Détection de déperditions thermiques, courts-circuits ou zones humides cachées grâce à la caméra thermique embarquée."
				image={feature03}
				link="/features"
			/>
		</Col>
		<Col span="4" classes="flex flex-col gap-6">
			<Card
				title="Prises de mesures & métré"
				subtitle="Relevés topographiques, calcul de surfaces, de volumes et de distances avec une précision centimétrique grâce au RTK."
				image={feature04}
				link="/features"
			/>
			<Card
				title="Rapport & livrables numériques"
				subtitle="Rapport d'inspection illustré, orthophotos, nuages de points 3D et vidéos HD livrés sous 48h après la mission."
				image={feature05}
				link="/features"
			/>
		</Col>
	</Row>
</Section>
